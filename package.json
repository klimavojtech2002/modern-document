{
  "name": "mcp-md-html-pdf",
  "version": "0.2.0",
  "description": "Markdown → branded HTML/PDF documents. CLI, MCP server, and web app.",
  "type": "module",
  "main": "src/core/index.js",
  "exports": {
    ".": "./src/core/index.js",
    "./mcp": "./src/mcp/server.js"
  },
  "bin": {
    "moddoc": "src/cli/index.js"
  },
  "files": [
    "src/core/",
    "src/mcp/",
    "src/cli/",
    "brands/",
    "LICENSE",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "test": "node --test test/*.test.js",
    "mcp": "node src/mcp/server.js"
  },
  "keywords": [
    "markdown",
    "document",
    "pdf",
    "html",
    "brand",
    "mcp",
    "mcp-server",
    "claude",
    "proposal",
    "invoice",
    "report",
    "contract",
    "branded-documents",
    "markdown-to-html",
    "markdown-to-pdf"
  ],
  "author": "Vojtech Klima",
  "license": "MIT",
  "homepage": "https://www.npmjs.com/package/mcp-md-html-pdf",
  "repository": {
    "type": "git",
    "url": "https://github.com/klimavojtech2002/modern-document.git"
  },
  "bugs": {
    "url": "https://github.com/klimavojtech2002/modern-document/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^3.24.4"
  },
  "optionalDependencies": {
    "puppeteer": "^24.0.0"
  },
  "devDependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.5.2",
    "vite": "^6.3.5"
  }
}
